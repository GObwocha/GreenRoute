# GreenRoute Environment Variables Template
# Copy this file to .env and replace the dummy values with your actual keys.
# NEVER commit the actual .env file to Git!

# Django Security Keys
SECRET_KEY=your_secure_django_secret_key_here
DEBUG=True

# Third-Party APIs
# Get your TomTom API key from https://developer.tomtom.com/
TOMTOM_API_KEY=your_tomtom_api_key_here
